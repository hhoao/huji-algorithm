# Copy to build.env and customize before running build scripts:
#   cp docker/build.env.example docker/build.env
#
# Registry is optional. Leave empty to build and tag locally only (no push).
DOCKER_REGISTRY=your-registry.example.com:5000

# Optional proxy (e.g. for pip install during image build)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
