# Copy to .env and fill in values (optional; config also supports application.yml)
# Environment keys use dots replaced by underscores, e.g. filesystem.cos.access_key_id

filesystem_cos_access_key_id=your-cos-access-key-id
filesystem_cos_access_key_secret=your-cos-access-key-secret
filesystem_cos_bucket_name=your-bucket-appid
internal_http_access_token=your-internal-access-token
JASYPT_PASSWORD=
